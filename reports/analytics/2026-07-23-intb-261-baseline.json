{
  "schemaVersion": "tabellio-analytics-dataset/v0.1",
  "id": "INTB-261-cross-repository-baseline",
  "observedAt": "2026-07-24T05:15:00.000Z",
  "window": {
    "since": "2026-07-01T00:00:00.000Z",
    "until": "2026-07-24T05:14:59.000Z"
  },
  "metricDefinitions": [
    {
      "id": "commitCount",
      "unit": "count",
      "definition": "Commits reachable from HEAD whose commit time falls inside the observation window.",
      "sourceSystems": [
        "git"
      ],
      "missingSemantics": "Unavailable when local Git cannot be read."
    },
    {
      "id": "validationAttemptCount",
      "unit": "count",
      "definition": "Tabellio validation results completed inside the observation window.",
      "sourceSystems": [
        "tabellio-validation"
      ],
      "missingSemantics": "Unavailable when the validation ref is absent or unreadable."
    },
    {
      "id": "validationPassRate",
      "unit": "ratio",
      "definition": "Passed validation attempts divided by all terminal validation attempts in the window.",
      "sourceSystems": [
        "tabellio-validation"
      ],
      "missingSemantics": "Unavailable when there are no terminal attempts; never reported as zero."
    },
    {
      "id": "costTelemetryCoverage",
      "unit": "ratio",
      "definition": "Validation attempts with complete required cost telemetry divided by validation attempts.",
      "sourceSystems": [
        "tabellio-validation"
      ],
      "missingSemantics": "Unavailable when there are no validation attempts."
    },
    {
      "id": "entireCheckpointCount",
      "unit": "count",
      "definition": "Distinct metadata-only Entire checkpoint sessions visible in the checkpoint ref.",
      "sourceSystems": [
        "entire"
      ],
      "missingSemantics": "Unavailable when the metadata ref is absent; transcript bodies are never read."
    },
    {
      "id": "reviewFindingCount",
      "unit": "count",
      "definition": "Review feedback records stored in Tabellio review cycles.",
      "sourceSystems": [
        "tabellio-review"
      ],
      "missingSemantics": "Unavailable when the review ref is absent."
    },
    {
      "id": "repairCount",
      "unit": "count",
      "definition": "Review fix records stored in Tabellio review cycles.",
      "sourceSystems": [
        "tabellio-review"
      ],
      "missingSemantics": "Unavailable when the review ref is absent."
    },
    {
      "id": "worktreeDirty",
      "unit": "boolean",
      "definition": "Whether Git reports tracked or untracked worktree changes at observation time.",
      "sourceSystems": [
        "git"
      ],
      "missingSemantics": "Unavailable when local Git cannot be read."
    },
    {
      "id": "evidenceCompleteness",
      "unit": "ratio",
      "definition": "Available evidence sources divided by the seven declared source systems.",
      "sourceSystems": [
        "git",
        "tabellio-validation",
        "tabellio-review",
        "entire",
        "plane",
        "github",
        "github-actions"
      ],
      "missingSemantics": "A missing source reduces completeness; it is not converted to zero-valued evidence."
    },
    {
      "id": "deliveryChangeCount",
      "unit": "count",
      "definition": "Delivery changes explicitly included in the sanitized provider snapshot.",
      "sourceSystems": [
        "plane",
        "github"
      ],
      "missingSemantics": "Unavailable when no provider snapshot is supplied."
    },
    {
      "id": "taskToPrTraceability",
      "unit": "ratio",
      "definition": "Delivery changes linked to both a Plane story and GitHub pull request divided by eligible delivery changes.",
      "sourceSystems": [
        "plane",
        "github"
      ],
      "missingSemantics": "Unavailable until compatible Plane and GitHub snapshots are supplied."
    },
    {
      "id": "leadTimeHours",
      "unit": "hours",
      "definition": "Elapsed time from work-item creation to merge for linked delivery changes.",
      "sourceSystems": [
        "plane",
        "github"
      ],
      "missingSemantics": "Unavailable until linked timestamps are supplied."
    },
    {
      "id": "cycleTimeHours",
      "unit": "hours",
      "definition": "Elapsed time from first implementation activity to merge for linked delivery changes.",
      "sourceSystems": [
        "git",
        "plane",
        "github"
      ],
      "missingSemantics": "Unavailable until linked timestamps are supplied."
    },
    {
      "id": "ciDisagreementRate",
      "unit": "ratio",
      "definition": "Candidates where hosted CI and exact-candidate validation disagree divided by compared candidates.",
      "sourceSystems": [
        "github-actions",
        "tabellio-validation"
      ],
      "missingSemantics": "Unavailable until hosted-check evidence is supplied."
    },
    {
      "id": "releaseLagHours",
      "unit": "hours",
      "definition": "Elapsed time from merge to first containing release.",
      "sourceSystems": [
        "github"
      ],
      "missingSemantics": "Unavailable until merge and release evidence is supplied."
    },
    {
      "id": "repositoryAdoption",
      "unit": "ratio",
      "definition": "Available Tabellio-native evidence sources divided by validation, review, and Entire sources.",
      "sourceSystems": [
        "tabellio-validation",
        "tabellio-review",
        "entire"
      ],
      "missingSemantics": "Measured from source availability, not commit volume or developer ranking."
    }
  ],
