{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/IntelIP/Tabellio/main/schemas/context-packet.schema.json",
  "title": "Tabellio native Git context packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "repository",
    "actor",
    "task",
    "refs",
    "changeSet",
    "checkpoints",
    "mergePreview",
    "createdAt",
    "integrity"
  ],
  "properties": {
    "schemaVersion": { "const": "tabellio-context/v0.1" },
    "runId": { "type": "string", "minLength": 1 },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "storage"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "not": { "pattern": "^(?:/|file:|[A-Za-z]:[\\\\/])|\\\\" } },
        "storage": { "const": "native-git" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "enum": ["human", "agent", "ci", "system"] },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "head", "mergeBase"],
      "properties": {
        "base": { "$ref": "#/$defs/namedCommit" },
        "head": { "$ref": "#/$defs/namedCommit" },
        "mergeBase": { "$ref": "#/$defs/namedCommit" }
      }
    },
    "changeSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "path"],
            "properties": {
              "status": { "type": "string", "pattern": "^(?:[ADMTUXB]|[RC][0-9]{1,3})$" },
              "path": { "type": "string", "minLength": 1 },
              "previousPath": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "commit", "digest"],
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "commit": { "$ref": "#/$defs/oid" },
          "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "summary": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    },
    "mergePreview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clean", "tree", "conflictFiles"],
      "properties": {
        "clean": { "type": "boolean" },
        "tree": { "anyOf": [{ "$ref": "#/$defs/oid" }, { "type": "null" }] },
        "conflictFiles": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "scope", "digest"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "scope": { "const": "canonical-json-without-integrity" },
        "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  },
  "$defs": {
    "oid": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "namedCommit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commit"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "commit": { "$ref": "#/$defs/oid" }
      }
    }
  }
}
