{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tabellio:schema:control-ref-operation:v0.1",
  "title": "Tabellio Control Ref Operation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "operation", "repository", "remote", "refs", "createdAt", "integrity"],
  "properties": {
    "schemaVersion": { "const": "tabellio-control-ref-operation/v0.1" },
    "operation": { "enum": ["publish", "fetch"] },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": { "id": { "type": "string", "minLength": 1 } }
    },
    "remote": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": { "type": "object", "properties": { "name": { "const": "refs/tabellio/reviews" } }, "required": ["name"] },
          "minContains": 0,
          "maxContains": 1
        },
        {
          "contains": { "type": "object", "properties": { "name": { "const": "refs/tabellio/validations" } }, "required": ["name"] },
          "minContains": 0,
          "maxContains": 1
        },
        {
          "contains": { "type": "object", "properties": { "name": { "const": "refs/heads/entire/checkpoints/v1" } }, "required": ["name"] },
          "minContains": 0,
          "maxContains": 1
        }
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "localOid", "remoteOid"],
        "properties": {
          "name": { "enum": ["refs/tabellio/reviews", "refs/tabellio/validations", "refs/heads/entire/checkpoints/v1"] },
          "localOid": { "type": ["string", "null"], "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
          "remoteOid": { "type": ["string", "null"], "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" }
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "digest"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "publish" } }, "required": ["operation"] },
      "then": {
        "properties": {
          "refs": {
            "items": {
              "properties": {
                "localOid": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "fetch" } }, "required": ["operation"] },
      "then": {
        "properties": {
          "refs": {
            "items": {
              "properties": {
                "remoteOid": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" }
              }
            }
          }
        }
      }
    }
  ]
}
